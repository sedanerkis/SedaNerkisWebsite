---
import PortraitImage from './PortraitImage.astro';
import { pageImages } from '../config/images';
---

<section class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-14 sm:px-6 md:grid-cols-[minmax(260px,400px)_1fr] md:py-20 lg:px-8">
  <div class="mx-auto w-full max-w-[400px]">
    <PortraitImage src={pageImages.home} class="shadow-sm" />
  </div>
  <div class="max-w-2xl">
    <h1 class="font-serif text-5xl font-bold leading-tight text-brown sm:text-6xl">Seda Nerkis</h1>
    <p class="mt-5 text-lg font-medium text-brown/80">
      Bilinçaltı Danışmanı · Eğitmen · Aile Danışmanı · Sosyolog
    </p>
    <p class="mt-6 text-lg leading-8 text-brown/75">
      Kendinizle daha derin, sakin ve dönüştürücü bir ilişki kurmak için bu yolculukta size eşlik ediyorum.
    </p>
    <a
      href="mailto:info@sedanerkis.com"
      class="mt-8 inline-flex rounded bg-terracotta px-6 py-3 text-sm font-semibold text-white transition hover:bg-brown"
    >
      Bize Ulaşın
    </a>
  </div>
</section>
